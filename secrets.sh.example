# secrets.sh.example — template for machine-specific secrets / private config.
#
# Copy this to secrets.sh and fill in real values. secrets.sh is git-ignored, so
# your secrets are never committed. init.sh sources ~/.dotfiles/secrets.sh for
# both bash and zsh; setup.sh / symlink.sh create it from this template on a new
# machine.
#
#   cp secrets.sh.example secrets.sh
#
# Example:
# export API_TOKEN="your-token-here"
# export PRIVATE_VAR="your-value"
# export GOOGLE_APPLICATION_CREDENTIALS="$HOME/your-service-account-key.json"

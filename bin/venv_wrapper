# include following in .bashrc / .bash_profile / .zshrc
# usage
# $ mkvenv myvirtualenv # creates venv under ~/.virtualenvs/
# $ venv myvirtualenv   # activates venv
# $ deactivate          # deactivates venv
# $ rmvenv myvirtualenv # removes venv

export VENV_HOME="$HOME/.virtualenvs"

venv() {
  if [ $# -eq 0 ]
    then
      source "./.venv/bin/activate"
      if [ $? -ne 0 ]
        then
          echo "Failed to activate .venv"
      fi
    else
      source "$VENV_HOME/$1/bin/activate"
      if [ $? -ne 0 ]
        then
          echo "Failed to activate $VENV_HOME/$1"
      fi
  fi
}

mkvenv() {
  local python_version="python3"
  local venv_name=".venv"

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -p|--python)
        python_version="$2"
        shift 2
        ;;
      *)
        venv_name="$1"
        shift
        ;;
    esac
  done

  # Create virtual environment
  if [ "$venv_name" = ".venv" ]; then
    "$python_version" -m venv ./.venv
    echo "Created .venv using $python_version"
    venv
  else
    "$python_version" -m venv "$VENV_HOME/$venv_name"
    echo "Created $venv_name using $python_version"
    venv "$venv_name"
  fi
}

rmvenv() {
  deactivate
  if [ $# -eq 0 ]
    then
      rm -rf ./.venv
      echo "Removed .venv"
    else
      rm -rf $VENV_HOME/$1
      echo "Removed $1"
  fi
}

#!/usr/bin/env python3
import os
import sys

# 1. Check if Ray is installed
try:
    from ray.job_submission import JobSubmissionClient
except ImportError:
    print("Error: The 'ray' package is not installed.")
    sys.exit(1)

# 2. Connect to Ray
dashboard_url = os.getenv("RAY_ADDRESS", "http://127.0.0.1:8265")
print(f"Connecting to Ray Dashboard at: {dashboard_url}")

try:
    client = JobSubmissionClient(dashboard_url)
    jobs = client.list_jobs()
except Exception as e:
    print(f"\nError: Could not connect to Ray at {dashboard_url}.")
    print(f"  - Details: {e}")
    sys.exit(1)

# 3. Filter and Stop
stopped_count = 0

# --- FIX IS HERE ---
# We access 'job_info.status.value' (or str(job_info.status)) to compare against strings.
# We explicitly check for both "RUNNING" and "PENDING".
active_job_infos = [
    job_info
    for job_info in jobs
    if str(job_info.status) in {"RUNNING", "PENDING"}
    or (
        hasattr(job_info.status, "value")
        and job_info.status.value in {"RUNNING", "PENDING"}
    )
]

print(
    f"Found {len(jobs)} total jobs. {len(active_job_infos)} are active (RUNNING or PENDING)."
)

for job_info in active_job_infos:
    job_id = job_info.job_id
    # Handle status printing whether it's an Enum or String
    status_str = (
        job_info.status.value
        if hasattr(job_info.status, "value")
        else str(job_info.status)
    )

    print(f"Stopping job: {job_id} (Status: {status_str})...")
    try:
        client.stop_job(job_id)
        stopped_count += 1
    except Exception as e:
        print(f"  Failed to stop {job_id}: {e}")

if stopped_count > 0:
    print(f"\nSuccess: Stopped {stopped_count} jobs.")
else:
    print("\nNo active jobs to stop.")

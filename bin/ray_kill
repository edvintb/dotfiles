#!/usr/bin/env python3
import os
import sys

# 1. Check if Ray is installed in the current environment
try:
    from ray.job_submission import JobSubmissionClient
except ImportError:
    print("Error: The 'ray' package is not installed in the current environment.")
    print(f"Current Python Interpreter: {sys.executable}")
    print("Try running: pip install 'ray[default]'")
    sys.exit(1)

# 2. Define the connection address (Head node defaults to localhost:8265)
dashboard_url = os.getenv("RAY_DASHBOARD_ADDRESS", "http://127.0.0.1:8265")

print(f"Connecting to Ray Dashboard at: {dashboard_url}")

try:
    client = JobSubmissionClient(dashboard_url)
    # Corrected: client.list_jobs() returns a list of JobInfo objects
    jobs = client.list_jobs()
except Exception as e:
    print(f"\nError: Could not connect to Ray at {dashboard_url}.")
    print("  - Is Ray running? (Run 'ray status')")
    print(f"  - Details: {e}")
    sys.exit(1)

# 3. Filter for active jobs and iterate
stopped_count = 0

# Filter the list of JobInfo objects to only include RUNNING or PENDING statuses
active_job_infos = [
    job_info for job_info in jobs
    if job_info.status in {"RUNNING", "PENDING"}
]

print(f"Found {len(jobs)} total jobs. {len(active_job_infos)} are active.")

# Now, iterate over the JobInfo objects and access their attributes
for job_info in active_job_infos:
    job_id = job_info.job_id  # Access the job_id attribute directly
    
    print(f"Stopping job: {job_id} (Status: {job_info.status.value})...")
    try:
        client.stop_job(job_id)
        stopped_count += 1
    except Exception as e:
        print(f"  Failed to stop {job_id}: {e}")

if stopped_count > 0:
    print(f"\nSuccess: Stopped {stopped_count} jobs.")
else:
    print("\nNo active jobs to stop.")

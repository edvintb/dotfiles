#!/bin/bash
# Runs by sshd on every incoming connection, before any shell.
# Repoints a stable symlink at the fresh agent-forwarding socket.

if [ -z "$SSH_AUTH_SOCK" ]; then
    echo "[ssh/rc] SSH_AUTH_SOCK not set, skipping symlink update" >&2
else
    old_target=$(readlink "$HOME/.ssh/ssh_auth_sock" 2>/dev/null)
    ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/ssh_auth_sock"
    echo "[ssh/rc] Updated symlink: $old_target -> $SSH_AUTH_SOCK" >&2
fi

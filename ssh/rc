#!/bin/bash
# Runs by sshd on every incoming connection, before any shell.
# Repoints a stable symlink at the fresh agent-forwarding socket.
# Always update: fresh socket from this connection is always the right one.
[ -n "$SSH_AUTH_SOCK" ] && [ "$SSH_AUTH_SOCK" != "$HOME/.ssh/ssh_auth_sock" ] && ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/ssh_auth_sock"
